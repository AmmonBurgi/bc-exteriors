# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Sender address (must be from a verified domain in Resend)
# For testing without a verified domain, use: onboarding@resend.dev
# and set RESEND_FROM=onboarding@resend.dev (can only send to your own Resend account email)
RESEND_FROM=B&C Exteriors Quote Form <onboarding@resend.dev>

# Port the Express API server listens on (optional, default 3001)
SERVER_PORT=3001

# Origin allowed by CORS (should match your Vite dev port)
CLIENT_ORIGIN=http://localhost:8080
