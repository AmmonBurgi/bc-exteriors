# SMTP credentials for Nodemailer
# Copy this file to .env and fill in your values

# SMTP host (e.g. smtp.gmail.com for Gmail, smtp.sendgrid.net for SendGrid)
SMTP_HOST=smtp.gmail.com

# SMTP port — 587 for TLS (recommended), 465 for SSL
SMTP_PORT=587

# Set to "true" only when using port 465
SMTP_SECURE=false

# Your sending email address / SMTP username
SMTP_USER=your-email@gmail.com

# App password or SMTP API key (NOT your regular login password)
# Gmail: https://myaccount.google.com/apppasswords
SMTP_PASS=your-app-password

# Port the Express API server listens on (optional, default 3001)
SERVER_PORT=3001

# Origin allowed by CORS (should match your Vite dev port)
CLIENT_ORIGIN=http://localhost:8080
